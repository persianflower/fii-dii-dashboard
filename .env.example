# Environment variables for FII/DII Dashboard
# Copy this to .env and fill in your values.

# Groq API key (optional) — for AI-powered summary generation
# Get one at https://console.groq.com/keys
# GROQ_API_KEY=

# Telegram alerting (optional) — for threshold breach notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
